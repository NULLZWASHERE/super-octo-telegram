{
  "version": 2,
  "builds": [
    {
      "src": "api/check.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/check", "dest": "/api/check.py" },
    { "src": "/api/stream", "dest": "/api/check.py" },
    { "src": "/", "dest": "/index.html" }
  ]
}
